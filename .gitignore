# ─── Python ───────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.env
*.egg-info/

# ─── Node & React (Frontend) ──────
frontend/node_modules/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.js
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ─── OS ───────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ──────────────────────────
.vscode/
.idea/

# ─── Temp / Logs ──────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
out.txt
err.txt
test_*

# Global image ignore rules
*.jpg
*.png

# EXCEPTION: Force Git to track screenshots for the README
!screenshots/
!screenshots/**